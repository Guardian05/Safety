-- ESP HELPERS (items)
local function clearESPForItem(itemName)
	local data = ESPRegistry[itemName]
	if not data then return end
	if data.highlights then
		for _, hl in pairs(data.highlights) do pcall(function() hl:Destroy() end) end
	end
	if data.labels then
		for _, lb in pairs(data.labels) do pcall(function() lb:Destroy() end) end
	end
	ESPRegistry[itemName] = nil
end

local function applyESPForItem(itemName, list, amount)
	clearESPForItem(itemName)

	local highlights = {}
	local labels = {}
	local count = math.min(amount, #list)
	local fakeData = { enabled = true }

	for i = 1, count do
		local item = list[i]
		if item and item:IsDescendantOf(workspace) then
			local part = item:FindFirstChild("Union")
				or item:FindFirstChildWhichIsA("BasePart")

			local hl = Instance.new("SelectionBox")
			hl.Adornee = item
			hl.Color3 = Color3.fromRGB(255, 200, 0)
			hl.LineThickness = 0.05
			hl.SurfaceTransparency = 0.6
			hl.SurfaceColor3 = Color3.fromRGB(255, 200, 0)
			hl.Parent = item
			table.insert(highlights, hl)

			if part then
				local billboard, distLabel = makeDistanceBillboard(part)
				table.insert(labels, billboard)

				local conn
				conn = RunService.Heartbeat:Connect(function()
					if not ESPRegistry[itemName] then
						conn:Disconnect()
						return
					end
					if not item:IsDescendantOf(workspace) then
						conn:Disconnect()
						pcall(function() billboard:Destroy() end)
						return
					end
					local char = LocalPlayer.Character
					if not char then return end
					local hrp = char:FindFirstChild("HumanoidRootPart")
					if not hrp then return end

					local dist = math.floor((hrp.Position - part.Position).Magnitude)
					distLabel.Text = dist .. "m"

					if dist <= 20 then
						distLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
					elseif dist <= 60 then
						distLabel.TextColor3 = Color3.fromRGB(255, 220, 0)
					else
						distLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
					end
				end)
			end
		end
	end

	ESPRegistry[itemName] = {
		highlights = highlights,
		labels = labels,
		enabled = true,
	}
end

UnespAllBtn.MouseButton1Click:Connect(function()
