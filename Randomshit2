			TPBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 200)
			TPBtn.TextColor3 = Color3.new(1, 1, 1)
			TPBtn.Font = Enum.Font.GothamBold
			TPBtn.TextSize = 13
			TPBtn.Text = "TP"
			TPBtn.Parent = Holder

			local TPCorner = Instance.new("UICorner")
			TPCorner.CornerRadius = UDim.new(0, 4)
			TPCorner.Parent = TPBtn

			local ESPItemBtn = Instance.new("TextButton")
			ESPItemBtn.Size = UDim2.new(0, 65, 0, 28)
			ESPItemBtn.Position = UDim2.new(0, 334, 0, 6)
			ESPItemBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
			ESPItemBtn.TextColor3 = Color3.new(1, 1, 1)
			ESPItemBtn.Font = Enum.Font.GothamBold
			ESPItemBtn.TextSize = 13
			ESPItemBtn.Text = "ESP"
			ESPItemBtn.Parent = Holder

			local ESPItemCorner = Instance.new("UICorner")
			ESPItemCorner.CornerRadius = UDim.new(0, 4)
			ESPItemCorner.Parent = ESPItemBtn

			if ESPRegistry[itemName] and ESPRegistry[itemName].enabled then
				ESPItemBtn.BackgroundColor3 = Color3.fromRGB(180, 140, 0)
				ESPItemBtn.Text = "ESP ✓"
			end

			ESPItemBtn.MouseButton1Click:Connect(function()
				local data = ESPRegistry[itemName]
				if data and data.enabled then
					clearESPForItem(itemName)
					ESPItemBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
					ESPItemBtn.Text = "ESP"
				else
					local amount = tonumber(AmountBox.Text) or 1
					applyESPForItem(itemName, list, amount)
					ESPItemBtn.BackgroundColor3 = Color3.fromRGB(180, 140, 0)
					ESPItemBtn.Text = "ESP ✓"
				end
			end)

			TPBtn.MouseButton1Click:Connect(function()
				local char = LocalPlayer.Character
				if not char then return end

				local hrp = char:FindFirstChild("HumanoidRootPart")
				if not hrp then return end

				local DragSystem = char:FindFirstChild("DragSystem")
				local DragItem = DragSystem and DragSystem:FindFirstChild("DragItem")

				local oldPos = hrp.CFrame
				local amount = tonumber(AmountBox.Text) or 1

				for i = 1, math.min(amount, #list) do
					if StopPickup then break end

					local item = list[i]

					if item and item:IsDescendantOf(workspace) then
						local part = item:FindFirstChild("Union")
							or item:FindFirstChildWhichIsA("BasePart")

						if part then
							-- TP instantly
							hrp.CFrame = part.CFrame + Vector3.new(0, 3, 0)

							-- Drag immediately
							if DragItem then
								DragItem:FireServer(item, part)
							end

							-- Pickup immediately
							if AdjustBackpackRemote then
								local backpackItem = ReplicatedStorage
									:WaitForChild("BackpackStorage", 5)
									:FindFirstChild(item.Name)
								if backpackItem then
									AdjustBackpackRemote:FireServer(backpackItem)
								end
							end

							-- Return immediately
							hrp.CFrame = oldPos
						end
					end
				end
			end)
		end
	end

	task.wait()

	Scroll.CanvasSize = UDim2.new(
		0, 0, 0,
		UIList.AbsoluteContentSize.Y + 10
	)
end

SearchBox:GetPropertyChangedSignal("Text"):Connect(refreshItems)

task.spawn(function()
	while true do
		task.wait(2)
		pcall(refreshItems)
	end
end)
