-- WORLD ESP HELPER
local function makeDistanceBillboard(part)
	local billboard = Instance.new("BillboardGui")
	billboard.Name = "ESPLabel"
	billboard.Size = UDim2.new(0, 80, 0, 25)
	billboard.StudsOffset = Vector3.new(0, 2.5, 0)
	billboard.AlwaysOnTop = true
	billboard.Adornee = part
	billboard.Parent = part

	local distLabel = Instance.new("TextLabel")
	distLabel.Size = UDim2.new(1, 0, 1, 0)
	distLabel.BackgroundTransparency = 1
	distLabel.TextColor3 = Color3.fromRGB(255, 220, 0)
	distLabel.TextStrokeTransparency = 0
	distLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	distLabel.Font = Enum.Font.GothamBold
	distLabel.TextSize = 13
	distLabel.Text = "..."
	distLabel.Parent = billboard

	return billboard, distLabel
end

local function startDistanceLoop(dataTable, item, part, billboard, distLabel)
	local conn
	conn = RunService.Heartbeat:Connect(function()
		if not dataTable.enabled then
			conn:Disconnect()
			return
		end
		if not item:IsDescendantOf(workspace) then
			conn:Disconnect()
			pcall(function() billboard:Destroy() end)
			return
		end
		local char = LocalPlayer.Character
		if not char then return end
		local hrp = char:FindFirstChild("HumanoidRootPart")
		if not hrp then return end

		local dist = math.floor((hrp.Position - part.Position).Magnitude)
		distLabel.Text = dist .. "m"

		if dist <= 20 then
			distLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
		elseif dist <= 60 then
			distLabel.TextColor3 = Color3.fromRGB(255, 220, 0)
		else
			distLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
		end
	end)
end

local function applyWorldESP(dataTable, objects, boxColor)
	for _, hl in pairs(dataTable.highlights) do pcall(function() hl:Destroy() end) end
	for _, lb in pairs(dataTable.labels) do pcall(function() lb:Destroy() end) end
	dataTable.highlights = {}
	dataTable.labels = {}

	for _, obj in pairs(objects) do
		if obj and obj:IsDescendantOf(workspace) then
			local part = obj:FindFirstChildWhichIsA("BasePart") or obj

			local hl = Instance.new("SelectionBox")
			hl.Adornee = obj
			hl.Color3 = boxColor
			hl.LineThickness = 0.05
			hl.SurfaceTransparency = 0.6
			hl.SurfaceColor3 = boxColor
			hl.Parent = obj
			table.insert(dataTable.highlights, hl)

			local billboard, distLabel = makeDistanceBillboard(part)
			table.insert(dataTable.labels, billboard)
			startDistanceLoop(dataTable, obj, part, billboard, distLabel)
		end
	end
end

local function clearWorldESP(dataTable)
	dataTable.enabled = false
	for _, hl in pairs(dataTable.highlights) do pcall(function() hl:Destroy() end) end
	for _, lb in pairs(dataTable.labels) do pcall(function() lb:Destroy() end) end
	dataTable.highlights = {}
	dataTable.labels = {}
end

