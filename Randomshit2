-- FUNCTIONS
local function getTool()
	local char = LocalPlayer.Character
	if not char then return nil end
	return char:FindFirstChild(WeaponName)
end

local function swing()
	local tool = getTool()
	if tool and tool:FindFirstChild("Swing") then
		tool.Swing:FireServer()
	end
end

local function hitTargets(targets)
	local tool = getTool()
	if tool and tool:FindFirstChild("HitTargets") then
		tool.HitTargets:FireServer(targets)
	end
end

-- AUTO FARM
local lastHit = 0

RunService.Heartbeat:Connect(function()
	if tick() - lastHit < Delay then return end
	lastHit = tick()

	local char = LocalPlayer.Character
	if not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end

	if AutoZombie then
		local targets = {}
		local ok, chars = pcall(function()
			return workspace:WaitForChild("Characters", 5):GetChildren()
		end)
		if ok then
			for _, mob in pairs(chars) do
				local hum = mob:FindFirstChildOfClass("Humanoid")
				local root = mob:FindFirstChild("HumanoidRootPart")
				if hum and hum.Health > 0 and root then
					if (hrp.Position - root.Position).Magnitude <= Range then
						table.insert(targets, mob)
					end
				end
			end
			if #targets > 0 then
				swing()
				hitTargets(targets)
			end
		end
	end

	if AutoScrap then
		local targets = {}
		local ok, structs = pcall(function()
			return workspace:WaitForChild("Structures", 5):GetChildren()
		end)
		if ok then
			for _, scrap in pairs(structs) do
				if scrap.Name == "Scrap Pile" then
					local part = scrap:FindFirstChildWhichIsA("BasePart")
					if part and (hrp.Position - part.Position).Magnitude <= Range then
						table.insert(targets, scrap)
					end
				end
			end
			if #targets > 0 then
				swing()
				hitTargets(targets)
			end
		end
	end
end)

